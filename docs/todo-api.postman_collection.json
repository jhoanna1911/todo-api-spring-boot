    {
      "name": "04 - CRUD de items",
      "description": "Flujo completo de items: agregar, editar descripción, togglear completado, eliminar. Cada paso verifica reflexión en GET /{id}.",
      "item": [
        {
          "name": "Agregar item nuevo (POST /items)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "const b = pm.response.json();",
              "pm.test('ahora hay 3 items', () => pm.expect(b.itemsTotalCount).to.eql(3));",
              "const nuevo = b.items.find(i => i.description === 'Item agregado por PATCH');",
              "pm.test('item aparece con la descripción enviada', () => pm.expect(nuevo).to.exist);",
              "pm.collectionVariables.set('newItemId', nuevo.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Item agregado por PATCH\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}/items", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}", "items"] }
          }
        },
        {
          "name": "Editar descripción de item (PUT /items/{id})",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const id = Number(pm.collectionVariables.get('itemId'));",
              "const item = pm.response.json().items.find(i => i.id === id);",
              "pm.test('descripción actualizada', () => pm.expect(item.description).to.eql('Correr tests - EDITADO'));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Correr tests - EDITADO\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}", "items", "{{itemId}}"] }
          }
        },
        {
          "name": "Marcar item como completado (PATCH /items/{id})",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('1 item completado', () => pm.expect(b.itemsCompletedCount).to.eql(1));",
              "const id = Number(pm.collectionVariables.get('itemId'));",
              "const item = b.items.find(i => i.id === id);",
              "pm.test('el item correcto está completed=true', () => pm.expect(item.completed).to.be.true);"
            ]}
          }],
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}/items/{{itemId}}?completed=true", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}", "items", "{{itemId}}"], "query": [{ "key": "completed", "value": "true" }] }
          }
        },
        {
          "name": "Eliminar item (DELETE /items/{id})",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('quedan 2 items', () => pm.expect(b.itemsTotalCount).to.eql(2));",
              "const deletedId = Number(pm.collectionVariables.get('secondItemId'));",
              "pm.test('item borrado ya no está', () => pm.expect(b.items.some(i => i.id === deletedId)).to.be.false);"
            ]}
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}/items/{{secondItemId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}", "items", "{{secondItemId}}"] }
          }
        },
        {
          "name": "GET /{id} refleja cambios en items",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('itemsTotalCount = 2 (después de add + delete)', () => pm.expect(b.itemsTotalCount).to.eql(2));",
              "pm.test('itemsCompletedCount = 1', () => pm.expect(b.itemsCompletedCount).to.eql(1));",
              "const editado = b.items.find(i => i.description === 'Correr tests - EDITADO');",
              "pm.test('descripción editada persiste', () => pm.expect(editado).to.exist);"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}"] }
          }
        }
      ]
    },
