{
  "info": {
    "name": "Todo API",
    "description": "Colección completa con validaciones end-to-end. Cada request valida status + body. Los tests confirman que los cambios se reflejan en GET /{id} y en el listado.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "b5a4c5a0-todo-api-imaginemos"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "itemId", "value": "", "type": "string" },
    { "key": "secondItemId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Flujo Happy Path",
      "item": [
        {
          "name": "1. Crear tarea con 2 items",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "const b = pm.response.json();",
              "pm.test('status SCHEDULED', () => pm.expect(b.status).to.eql('SCHEDULED'));",
              "pm.test('2 items totales', () => pm.expect(b.itemsTotalCount).to.eql(2));",
              "pm.collectionVariables.set('taskId', b.id);",
              "pm.collectionVariables.set('itemId', b.items[0].id);",
              "pm.collectionVariables.set('secondItemId', b.items[1].id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Release v1.0\",\n  \"description\": \"Checklist inicial\",\n  \"executionDate\": \"2026-05-01T10:00:00\",\n  \"itemDescriptions\": [\"Correr tests\", \"Actualizar changelog\"]\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks", "host": ["{{baseUrl}}"], "path": ["v1", "tasks"] }
          }
        }
      ]
    },
    {
      "name": "02 - Edición de campos (title, description, executionDate)",
      "item": [
        {
          "name": "Editar título",
          "event": [{
