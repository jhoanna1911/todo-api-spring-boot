          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/v1/tasks/999999", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "999999"] } }
        },
        {
          "name": "400 - Transición inválida",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const base = pm.collectionVariables.get('baseUrl');",
                "pm.sendRequest({ url: base + '/v1/tasks', method: 'POST', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify({ title: 'Error 400 test' }) } }, (e, r) => {",
                "  const id = r.json().id; pm.collectionVariables.set('tempTaskId', id);",
                "  pm.sendRequest({ url: base + '/v1/tasks/' + id + '/status', method: 'PATCH', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify({ newStatus: 'IN_PROGRESS' }) } }, () => {",
                "    pm.sendRequest({ url: base + '/v1/tasks/' + id + '/status', method: 'PATCH', header: { 'Content-Type': 'application/json' }, body: { mode: 'raw', raw: JSON.stringify({ newStatus: 'COMPLETED' }) } }, () => {});",
                "  });",
                "});"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('400', () => pm.response.to.have.status(400));",
                "pm.test('mensaje transición inválida', () => pm.expect(pm.response.json().message).to.include('Invalid state transition'));"
              ]}
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"newStatus\": \"IN_PROGRESS\" }" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{tempTaskId}}/status", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{tempTaskId}}", "status"] }
          }
        },
