              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('title actualizado', () => pm.expect(pm.response.json().title).to.eql('Release v1.0 - EDITADO'));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Release v1.0 - EDITADO\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "Editar descripción",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('description actualizada', () => pm.expect(pm.response.json().description).to.eql('Descripción nueva'));",
              "pm.test('title NO cambió (patch parcial)', () => pm.expect(pm.response.json().title).to.eql('Release v1.0 - EDITADO'));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Descripción nueva\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "Editar executionDate",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('executionDate actualizada', () => pm.expect(pm.response.json().executionDate).to.include('2026-06-15'));"
            ]}
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"executionDate\": \"2026-06-15T09:00:00\"\n}" },
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "GET /{id} refleja TODOS los cambios",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('title persistido', () => pm.expect(b.title).to.eql('Release v1.0 - EDITADO'));",
              "pm.test('description persistida', () => pm.expect(b.description).to.eql('Descripción nueva'));",
              "pm.test('executionDate persistida', () => pm.expect(b.executionDate).to.include('2026-06-15'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["v1", "tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "GET / (listado) refleja los cambios",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const taskId = Number(pm.collectionVariables.get('taskId'));",
              "const found = pm.response.json().content.find(t => t.id === taskId);",
              "pm.test('tarea presente en listado', () => pm.expect(found).to.exist);",
              "pm.test('título editado presente en listado', () => pm.expect(found.title).to.eql('Release v1.0 - EDITADO'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/tasks?page=0&size=50&sort=createdAt,desc", "host": ["{{baseUrl}}"], "path": ["v1", "tasks"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "50" }, { "key": "sort", "value": "createdAt,desc" }] }
          }
        }
      ]
    },
    {
      "name": "03 - Cambios de estado",
      "item": [
        {
          "name": "SCHEDULED -> IN_PROGRESS",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
